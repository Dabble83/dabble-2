// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum SkillCategory {
  Adventure
  HomeImprovement
  Creative
}

enum SkillLevel {
  Beginner
  Intermediate
  Advanced
  Expert
}

enum SkillType {
  INTEREST
  GUIDE
}

enum UserRole {
  Dabbler
  Guide
  Both
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime @default(now())

  profile   Profile?
  userSkills UserSkill[]

  @@map("users")
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  city         String
  state        String
  zip          String?
  radiusMiles  Int      @default(10)
  isDabbler    Boolean  @default(false)
  isGuide      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Skill {
  id         String        @id @default(cuid())
  category   SkillCategory
  name       String
  createdAt  DateTime      @default(now())

  userSkills UserSkill[]

  @@unique([category, name])
  @@map("skills")
}

model UserSkill {
  id       String     @id @default(cuid())
  userId   String
  skillId  String
  type     SkillType
  level    SkillLevel

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId, type])
  @@map("user_skills")
  @@index([userId])
  @@index([skillId])
}
