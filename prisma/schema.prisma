// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum SkillCategory {
  Adventure
  HomeImprovement
  Creative
}

enum LocationPrecision {
  neighborhood
  approximate
}

enum ProfileSkillType {
  offers
  wants
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  name         String
  phone        String?
  createdAt    DateTime @default(now())

  profile Profile?

  @@map("users")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  username        String   @unique
  displayName     String
  profileImageUrl String?
  interestsIntro  String?
  skillsIntro     String?
  interests       String   @default("[]") // JSON array stored as string in SQLite
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  location        ProfileLocation?
  profileSkills   ProfileSkill[]

  @@map("profiles")
}

model ProfileLocation {
  id            String            @id @default(cuid())
  profileId     String            @unique
  isDiscoverable Boolean          @default(false)
  addressLabel String
  lat           Float?
  lng           Float?
  precision     LocationPrecision @default(neighborhood)
  updatedAt     DateTime          @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_locations")
}

model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  SkillCategory?
  createdAt DateTime @default(now())

  profileSkills ProfileSkill[]

  @@map("skills")
}

model ProfileSkill {
  profileId String
  skillId    String
  type       ProfileSkillType

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([profileId, skillId, type])
  @@map("profile_skills")
  @@index([profileId])
  @@index([skillId])
}
