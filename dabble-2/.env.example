##
# Dabble 2.0 — example environment file
#
# Copy to `.env.local` for local dev and set the same values in Vercel.
# Do NOT commit `.env.local`.
##

## Supabase (required for auth/profile/explore APIs)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only (Route Handlers). Never expose as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

## Maps (optional; list-first Explore works without maps)
NEXT_PUBLIC_ENABLE_MAPS=false
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_KEY=

## AI (optional)
OPENAI_API_KEY=

